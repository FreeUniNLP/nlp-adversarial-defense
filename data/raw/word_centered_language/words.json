      "agency":      "0=passive, 1=operates, 2=instinct-driven, 3=fully deliberate",
      "physicality": "0=abstract, 1=place/structure, 2=manufactured, 3=tangible-organic",
      "social":      "0=none, 1=relational-concept, 2=group-aware, 3=fully-social",
      "system":      "0=organic, 1=simple-mechanical, 2=rule-governed, 3=computational"
    },
    "argument_constraints": {
      "agency_min":      "subject/object must have agency >= this",
      "agency_max":      "subject/object must have agency <= this",
      "physicality_min": "subject/object must have physicality >= this",
      "physicality_max": "subject/object must have physicality <= this",
      "social_min":      "subject/object must have social >= this",
      "social_max":      "subject/object must have social <= this",
      "system_min":      "subject/object must have system >= this",
      "system_max":      "subject/object must have system <= this",
      "tags_any":        "noun must have at least one of these tags"
    },
    "adjective_fields": {
      "modifies":    "how this adjective shifts noun axes (applied before verb validation)",
      "constraints": "noun must satisfy these before adjective can apply"
    }
  },

