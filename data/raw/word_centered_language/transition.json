{
  "start_symbol": "S",

  "rules": {

    "S": [
      ["NP"]
    ],

    "VP_CHAIN": [
      ["VP"],
      ["VP", "VP_CHAIN"]
    ],

    "VP": [
      ["VERB"],
      ["VERB", "NP"]
    ],

    "NP": [
      ["NOUN"],
      ["ADJ", "NOUN"],
      ["ADJ", "ADJ", "NOUN"]
    ],

    "SP":
  }
}


START -> SUBJECT
SUBJECT -> [VERB TERM ....]
VERB TERM = VERB + OBJECT | VERB
OBJECT -> NOUN | ADJ + NOUN | ADJ + ADJ + NOUN
SUBJECT -> NOUN | ADJ + NOUN | ADJ + ADJ + NOUN



