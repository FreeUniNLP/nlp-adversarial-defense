    "note_on_verb_adj_categories": "Verb-category and adjective-category transition matrices are not yet defined. Until they are, all intra-verb-category and intra-adjective-category transitions are structurally absent."
  },

  "pos_illegal_transitions": {
    "description": "Illegal transitions between POS types (START, NOUN, VERB, ADJ, END). Any sequence containing one of these consecutive POS pairs is illegal.",
    "transitions": [
      { "from": "START", "to": "VERB" },
      { "from": "START", "to": "END" },
      { "from": "START", "to": "START" },
      { "from": "NOUN", "to": "START" },
      { "from": "ADJ", "to": "VERB" },
      { "from": "ADJ", "to": "ADJ" },
      { "from": "ADJ", "to": "END" },
      { "from": "ADJ", "to": "START" },
      { "from": "VERB", "to": "VERB" },
      { "from": "VERB", "to": "END" },
      { "from": "VERB", "to": "START" },
      { "from": "END", "to": "NOUN" },
      { "from": "END", "to": "VERB" },
      { "from": "END", "to": "ADJ" },
      { "from": "END", "to": "START" },
      { "from": "END", "to": "END" }
    ]
  },


